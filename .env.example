# Deployment flavor
# - default: current Vercel + Supabase oriented setup
# - production-cn: reserved for mainland China deployment variants
NEXT_PUBLIC_TP_DEPLOYMENT_FLAVOR=default

# Public app/API endpoints
# - Keep APP_BASE_URL aligned with the deployed frontend origin
# - API_BASE_URL is reserved for future custom API gateways
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=

# Auth/storage provider switches
# - supabase: current implementation
# - custom-api / object-storage: future migration targets
NEXT_PUBLIC_TP_AUTH_MODE=supabase
NEXT_PUBLIC_TP_STORAGE_MODE=supabase

# Supabase runtime credentials
# Required when auth/storage mode stays on supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Recommended for trusted server-side writes that should bypass RLS after app-level permission checks
SUPABASE_SERVICE_ROLE_KEY=

# Local-only demo mode
# Set to true only for local development without Supabase credentials
NEXT_PUBLIC_TP_ENABLE_DEMO_MODE=false

# Bootstrap admin compatibility
# Comma-separated emails for the temporary bootstrap access path.
# Long-term admin access should converge on profiles.role=super_admin.
NEXT_PUBLIC_BOOTSTRAP_ADMIN_EMAILS=zhangyuheng_andy@163.com
